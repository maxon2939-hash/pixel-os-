name: Build PixelOS Android 16 QPR1 Nothing 3A

on:
  workflow_dispatch:   # permite rularea manuală
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 360

    steps:
      # 1️⃣ Checkout cod repo
      - name: Checkout
        uses: actions/checkout@v3

      # 2️⃣ Instalare dependințe
      - name: Install dependencies
        run: |
          sudo apt update
          sudo apt install -y openjdk-17-jdk python3 git-core bc ccache zip unzip repo

      # 3️⃣ Initialize PixelOS manifest QPR1
      - name: Initialize PixelOS QPR1
        run: |
          mkdir -p ~/pixelos_qpr1 && cd ~/pixelos_qpr1
          repo init -u https://github.com/PixelOS-AOSP/manifest.git -b PixelOS_Android-16_QPR1
          repo sync -c -j4 --no-clone-bundle --no-tags

      # 4️⃣ Clone device & vendor pentru Nothing 3A
      - name: Clone device & vendor
        run: |
          git clone https://github.com/pixelos-asteroids/device_nothing_3a.git device/nothing/3a
          git clone https://github.com/pixelos-asteroids/vendor_nothing_3a.git vendor/nothing/3a

      # 5️⃣ Setup build environment
      - name: Setup environment
        run: |
          export USE_CCACHE=1
          export CCACHE_DIR=/tmp/ccache
          ccache -M 10G
          source build/envsetup.sh
          lunch pixel_3a-userdebug

